import { Button, VerticalBox, ScrollView } from "std-widgets.slint";

// Discovered LAN peer
export struct DiscoveredPeer {
    name: string,
    addr: string,
}

// Saved contact from address book
export struct ContactInfo {
    name: string,
    fingerprint: string,
    online: bool,
}

// File info model for dynamic file list
export struct FileInfo {
    name: string,
    size-bytes: int,
    downloading: bool,    // I'm downloading this file
    uploading: bool,      // peer is downloading this file from me
    progress: float,      // 0.0 to 1.0
    saved: bool,
    paused: bool,         // download was paused (can resume)
    file-type: string,    // "pdf", "image", "video", "audio", "code", "archive", "text", "other"
    is-local: bool,       // true = my file (shared by me), false = remote file (from peer)
}

component InputArea inherits Rectangle {
    in-out property <string> inText: "xxx-xxx-xxx";
    in property <bool> readOnly: false;
    in property <string> buttonText: "Copy";

    callback process_code;

    width: 438px;
    height: 34px;
    border-radius: 7px;
    border-width: 0.5px;
    border-color: rgba(255,255,255,0.5);
    background: #222222;
    clip: true;

    // Input text area (left portion)
    if root.readOnly: Text {
        x: 8px;
        width: 288px;
        height: parent.height;
        text: root.inText;
        color: white;
        font-family: "monospace";
        font-size: 11px;
        vertical-alignment: center;
        overflow: elide;
    }

    if !root.readOnly: TextInput {
        x: 8px;
        width: 288px;
        height: parent.height;
        horizontal-alignment: left;
        vertical-alignment: center;
        font-family: "monospace";
        font-size: 12px;
        color: white;
        text <=> root.inText;
        single-line: true;
        accepted => { root.process_code(); }
    }

    // White divider line
    Rectangle {
        x: 296px;
        y: 0px;
        width: 0.5px;
        height: parent.height;
        background: rgba(255,255,255,0.5);
    }

    // Button (right portion, inside the pill)
    Rectangle {
        x: 296px;
        y: 0px;
        width: 142px;
        height: parent.height;
        background: btn-touch.pressed ? #777777 : btn-touch.has-hover ? #999999 : #888888;
        animate background { duration: 150ms; }

        Text {
            text: root.buttonText;
            color: black;
            font-size: 14px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        btn-touch := TouchArea {
            clicked => { root.process_code(); }
        }
    }
}

component DataRectangle inherits Rectangle {
    in property <string> info: "code";
    in-out property <string> inText;
    in property <string> buttonText;
    in property <bool> readOnly;
    in property <string> helperText: "";

    callback process_code;

    width: 517px;
    height: 100%;

    t := Text {
        x: 43px;
        y: 30px;
        text: parent.info;
        color: white;
        font-size: 16px;
        font-weight: 600;
    }

    InputArea {
        x: 43px;
        y: 62px;
        inText <=> parent.inText;
        buttonText: parent.buttonText;
        readOnly: parent.readOnly;
        process_code => { parent.process_code() }
    }

    if root.helperText != "": Text {
        x: 43px;
        y: 120px;
        width: parent.width - 86px;
        text: root.helperText;
        color: #6A6A6A;
        font-size: 12px;
        wrap: word-wrap;
    }
}

component NumberedToolTip inherits Rectangle {
    in property <int> number: 1;
    width: 34px;
    height: 34px;
    border-width: 0.5px;
    border-color: white;
    border-radius: 7px;
    background: transparent;

    Text {
        text: number;
        color: #6A6A6A;
        font-size: 14px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component CodeRectangle inherits Rectangle {
    in property <string> info: "code";
    in-out property <string> inText;
    in property <string> buttonText;
    in property <bool> readOnly;
    in property <string> helperText: "";
    out property <string> codeData;

    callback process_code;

    width: 517px;
    height: 170px;
    border-width: 0.5px;
    border-color: white;
    border-radius: 7px;
    background: #262626;

    DataRectangle {
        width: parent.width;
        height: parent.height;
        info: parent.info;
        inText <=> parent.inText;
        buttonText: parent.buttonText;
        readOnly: parent.readOnly;
        helperText: parent.helperText;
        process_code => { parent.process_code() }
    }
}

component SectionElement inherits Rectangle {
    in property <string> info: "code";
    in-out property <string> inText;
    in property <string> buttonText;
    in property <bool> readOnly;
    in property <int> sectionNumber;
    in property <string> helperText: "";

    callback process_code;

    height: 178px;
    width: 570px;

    nt := NumberedToolTip {
        number: parent.sectionNumber;
        x: 0;
        y: 0;
    }

    CodeRectangle {
        x: nt.x + nt.width + 19px;
        y: 0;
        height: parent.height;
        info: parent.info;
        inText <=> parent.inText;
        readOnly: parent.readOnly;
        buttonText: parent.buttonText;
        helperText: parent.helperText;
        process_code => { parent.process_code() }
    }
}

// Toggle switch (reusable for FUSE and local mode)
component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled(bool);

    width: 36px;
    height: 20px;
    border-radius: 7px;
    background: root.checked ? #3b82f6 : #363434;
    animate background { duration: 150ms; }

    Rectangle {
        x: root.checked ? parent.width - self.width - 2px : 2px;
        y: 2px;
        width: 16px;
        height: 16px;
        border-radius: 5px;
        background: white;
        animate x { duration: 150ms; easing: ease-out; }
    }

    TouchArea {
        enabled: root.enabled;
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

// Pill button with blue outline (Create/Join room)
component PillButton inherits Rectangle {
    in-out property <string> text: "Button";
    in property <bool> enabled: true;
    in property <bool> active: false;
    callback clicked;

    width: 161px;
    height: 34px;
    border-radius: 7px;
    border-width: 0.5px;
    background: root.active ? #177DF5 : #222222;
    border-color: !root.enabled ? #555
               : pill-touch.pressed ? #125ec0
               : pill-touch.has-hover ? #4a9af7
               : #177DF5;

    Text {
        text: root.text;
        color: root.active ? white
             : !root.enabled ? #555
             : pill-touch.pressed ? #125ec0
             : pill-touch.has-hover ? #4a9af7
             : #177DF5;
        font-size: 14px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    pill-touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    animate background { duration: 150ms; }
    animate border-color { duration: 150ms; }
}

// Small outline button (Save Log, ?, X)
component SmallOutlineButton inherits Rectangle {
    in-out property <string> text: "?";
    callback clicked;

    width: self.preferred-width;
    preferred-width: btn-label.preferred-width + 28px;
    height: 24px;
    border-radius: 7px;
    border-width: 0.5px;
    border-color: small-touch.pressed ? #ccc : small-touch.has-hover ? #bbb : white;
    background: transparent;

    btn-label := Text {
        text: root.text;
        color: small-touch.pressed ? #bbb : small-touch.has-hover ? #aaa : #888888;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    small-touch := TouchArea {
        clicked => { root.clicked(); }
    }

    animate border-color { duration: 150ms; }
}

component KeibiDropLogo inherits Rectangle {
    width: 195px;
    height: 24px;

    Image {
        width: parent.width;
        height: parent.height;
        source: @image-url("../assets/logo.svg");
        image-fit: contain;
    }
}


// Outline button - white/grey by default, set accent: true for blue
component OutlineButton inherits Rectangle {
    in-out property <string> text: "Button";
    in property <bool> enabled: true;
    in property <bool> accent: false;
    callback clicked;

    width: 161px;
    height: 34px;
    background: touch.pressed ? (accent ? rgba(59,130,246,0.15) : rgba(255,255,255,0.08))
              : touch.has-hover ? (accent ? rgba(59,130,246,0.08) : rgba(255,255,255,0.04))
              : transparent;
    border-width: 1px;
    border-radius: 8px;
    border-color: !enabled ? #555
               : accent ? (touch.pressed ? #2563eb : touch.has-hover ? #60a5fa : #3b82f6)
               : (touch.pressed ? #ccc : touch.has-hover ? #bbb : #888);

    Text {
        text: root.text;
        color: !root.enabled ? #555
             : root.accent ? (touch.pressed ? #2563eb : touch.has-hover ? #60a5fa : #3b82f6)
             : (touch.pressed ? #fff : touch.has-hover ? #ddd : #aaa);
        font-size: 14px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    animate border-color { duration: 150ms; }
    animate background { duration: 150ms; }
}

// Spinner arc with always-visible "+" center, clickable
component SpinnerArc inherits Rectangle {
    in property <length> size: 180px;
    in property <bool> spinning: false;
    callback clicked;

    width: size;
    height: size;

    // Continuous rotation using animation-tick
    property <float> angle: mod(animation-tick() / 8ms, 360);

    // Background ring (always visible)
    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: self.width / 2;
        border-width: 6px;
        border-color: #334155;
        background: transparent;
    }

    // Rotating arc (only when spinning)
    if root.spinning: Path {
        x: 0;
        y: 0;
        width: root.size;
        height: root.size;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 100;
        viewbox-height: 100;
        stroke: #3b82f6;
        stroke-width: 3px;
        stroke-line-cap: round;
        fill: transparent;

        property <float> start: angle;
        property <float> arc-len: 90;
        property <float> r: 47;
        property <float> cx: 50;
        property <float> cy: 50;

        property <float> x1: cx + r * sin(start * 1deg);
        property <float> y1: cy - r * cos(start * 1deg);
        property <float> x2: cx + r * sin((start + arc-len) * 1deg);
        property <float> y2: cy - r * cos((start + arc-len) * 1deg);

        commands: "M " + x1 + " " + y1 + " A " + r + " " + r + " 0 0 1 " + x2 + " " + y2;
    }

    // Center "+" icon (always visible)
    Text {
        text: "+";
        font-size: root.size * 0.35;
        color: spinner-touch.has-hover ? #60a5fa : #3b82f6;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: 150ms; }
    }

    spinner-touch := TouchArea {
        clicked => { root.clicked() }
    }
}

// Small spinner for file cards - shows progress 0->100%
component SmallSpinner inherits Rectangle {
    in property <bool> active: true;
    in property <color> accent: #3b82f6;  // blue default
    in property <float> progress: 0.0;    // 0.0 to 1.0

    width: 20px;
    height: 20px;

    // Slow rotation so it looks alive even at fixed progress
    property <float> angle: active ? mod(animation-tick() / 10ms, 360) : 0;

    // Background circle (track)
    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: self.width / 2;
        background: root.accent.darker(60%);
    }

    // Progress arc: arc-len = progress * 360° (min 30° so it's always visible when active)
    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 20;
        viewbox-height: 20;
        stroke: root.accent;
        stroke-width: 2px;
        stroke-line-cap: round;
        fill: transparent;

        property <float> r: 7;
        property <float> cx: 10;
        property <float> cy: 10;
        property <float> start: angle;
        property <float> arc-len: clamp(root.progress * 340, 30, 340);
        // large-arc flag: 1 if arc > 180°
        property <float> large: arc-len > 180 ? 1 : 0;

        property <float> x1: cx + r * sin(start * 1deg);
        property <float> y1: cy - r * cos(start * 1deg);
        property <float> x2: cx + r * sin((start + arc-len) * 1deg);
        property <float> y2: cy - r * cos((start + arc-len) * 1deg);

        commands: "M " + x1 + " " + y1 + " A " + r + " " + r + " 0 " + large + " 1 " + x2 + " " + y2;
    }
}

// File type icon (emoji-based placeholder for different file types)
component FileTypeIcon inherits Rectangle {
    in property <string> file-type: "other";

    width: 48px;
    height: 48px;
    background: transparent;

    // Icon text based on file type
    Text {
        text: root.file-type == "folder" ? "DIR"
            : root.file-type == "pdf" ? "PDF"
            : root.file-type == "image" ? "IMG"
            : root.file-type == "video" ? "VID"
            : root.file-type == "audio" ? "SND"
            : root.file-type == "code" ? "</>"
            : root.file-type == "archive" ? "ZIP"
            : root.file-type == "text" ? "TXT"
            : "FILE";
        color: root.file-type == "folder" ? #60a5fa
             : root.file-type == "pdf" ? #ef4444
             : root.file-type == "image" ? #22c55e
             : root.file-type == "video" ? #a855f7
             : root.file-type == "audio" ? #f59e0b
             : root.file-type == "code" ? #3b82f6
             : root.file-type == "archive" ? #f97316
             : #9ca3af;
        font-size: 16px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Progress bar
component ProgressBar inherits Rectangle {
    in property <float> progress: 0.0;  // 0.0 to 1.0

    width: 100%;
    height: 4px;
    background: #334155;
    border-radius: 2px;

    Rectangle {
        width: parent.width * clamp(root.progress, 0, 1);
        height: 100%;
        background: root.progress >= 1.0 ? #22c55e : #3b82f6;
        border-radius: 2px;

        animate width { duration: 300ms; easing: ease-out; }
        animate background { duration: 300ms; }
    }
}

// File card for non-FUSE mode (original design + progress)
component FileCard inherits Rectangle {
    in property <string> filename: "Project 123";
    in property <string> file-type: "other";
    in property <int> size-bytes: 0;
    in property <bool> downloading: false;
    in property <bool> uploading: false;
    in property <float> progress: 0.0;
    in property <bool> saved: false;
    in property <bool> is-local: false;
    in property <bool> paused: false;
    in property <bool> browse-mode: false;

    callback save-clicked;
    callback open-clicked;
    callback pause-clicked;
    callback delete-clicked;

    width: 250px;
    height: 180px;
    background: transparent;

    // Glass card background
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: 12px;
        background: rgba(255,255,255,0.03);
        border-width: 1px;
        border-color: rgba(255,255,255,0.08);
    }

    // Preview area (original grey style)
    Rectangle {
        width: parent.width;
        height: 140px;
        background: #3a3a3a;
        border-radius: 4px;

        // File type icon centered
        FileTypeIcon {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2 - 10px;
            file-type: root.file-type;
        }

        // Green spinner: downloading from peer (top-left)
        if root.downloading: SmallSpinner {
            x: 8px;
            y: 8px;
            active: true;
            accent: #22c55e;
        }

        // Blue spinner: uploading to peer (top-right)
        if root.uploading: SmallSpinner {
            x: parent.width - 28px;
            y: 8px;
            active: true;
            accent: #3b82f6;
        }

        // Progress bar at bottom of preview area
        if root.downloading: ProgressBar {
            x: 8px;
            y: parent.height - 18px;
            width: parent.width - 16px;
            progress: root.progress;
        }

        // Progress: percentage and size
        if root.downloading: Text {
            x: 8px;
            y: parent.height - 14px;
            text: Math.round(root.progress * 100) + "%";
            color: #22c55e;
            font-size: 10px;
        }
        if root.downloading && root.size-bytes > 0: Text {
            x: parent.width - 8px;
            y: parent.height - 14px;
            horizontal-alignment: right;
            text: root.size-bytes > 1073741824
                ? Math.round(root.size-bytes / 10737418.24) / 100 + " GB"
                : root.size-bytes > 1048576
                ? Math.round(root.size-bytes / 10485.76) / 100 + " MB"
                : root.size-bytes > 1024
                ? Math.round(root.size-bytes / 10.24) / 100 + " KB"
                : root.size-bytes + " B";
            color: #888;
            font-size: 9px;
        }

        // Saved checkmark
        if root.saved && !root.downloading: Text {
            x: parent.width - 30px;
            y: 8px;
            text: "OK";
            color: #22c55e;
            font-size: 12px;
            font-weight: 700;
        }
    }

    // Bottom row (matches design: checkbox + name + button)
    HorizontalLayout {
        y: 148px;
        height: 28px;
        spacing: 8px;

        // Checkbox - shows progress spinner while downloading (hidden in browse mode)
        if root.downloading && !root.browse-mode: SmallSpinner {
            width: 20px;
            height: 20px;
            active: true;
            accent: #22c55e;
            progress: root.progress;
        }
        if !root.downloading && !root.browse-mode: Rectangle {
            width: 20px;
            height: 20px;
            border-width: 1px;
            border-color: #666;
            border-radius: 4px;
        }

        Text {
            text: filename;
            color: white;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }

        OutlineButton {
            width: 60px;
            height: 28px;
            text: root.paused ? "Resume" : "Pause";
            visible: root.downloading || root.paused;
            clicked => { root.pause-clicked(); }
        }

        OutlineButton {
            width: 80px;
            height: 28px;
            // "Open" is blue accent, "Save" is white/grey
            accent: root.is-local || root.saved;
            text: root.file-type == "folder" ? "Open"
                : root.downloading ? Math.round(root.progress * 100) + "%"
                : root.paused ? Math.round(root.progress * 100) + "%"
                : root.is-local ? "Open"
                : root.saved ? "Open"
                : "Save";
            enabled: root.file-type == "folder" || !root.downloading || root.paused;
            clicked => {
                if (root.file-type == "folder") { root.open-clicked(); }
                else if (root.paused) { root.save-clicked(); }
                else if (root.is-local || root.saved) { root.open-clicked(); }
                else { root.save-clicked(); }
            }
        }

        if root.browse-mode: SmallOutlineButton {
            width: 24px;
            text: "X";
            clicked => { root.delete-clicked(); }
        }
    }
}



export component MainWindow inherits Window {
    title: "KEIBIDROP";
    default-font-family: "Inter";
    preferred-width: 1144px;
    preferred-height: 760px;
    min-width: 1144px;
    min-height: 760px;
    background: #222222;

    // Data bindings from Rust
    in property<string> my_code: "XXXX-XXXX-XXXX-XXXX";
    in-out property<string> peer_code: "";
    in property<bool> next_enabled: true;

    // Screen state: 0 = connect, 1 = connected (no-fuse), 2 = connected (fuse)
    in-out property<int> current_screen: 0;

    // Error message (shown on connect screen)
    in-out property<string> error_message: "";

    // Room action state: 0=none, 1=creating, 2=joining
    in-out property<int> room_action: 0;
    // Status message (shown below buttons on connect screen)
    in-out property<string> status_message: "";

    // Dynamic file list model (populated by Rust file watcher)
    in-out property<[FileInfo]> file_list: [];
    // Current folder path for navigation (empty = root)
    in-out property<string> current_folder: "";
    callback navigate_folder(string);
    callback back_folder();
    // Set by Rust when any file is actively downloading
    in-out property<bool> any_downloading: false;
    // Set by Rust when a file is being dragged over the window
    in-out property<bool> drag_hovering: false;
    // Mount path for FUSE mode (Screen 2)
    in property<string> mount_path: "";
    in property<string> connection_mode: ""; // "lan", "direct", "bridge"
    // Toast message (brief feedback shown at bottom-center, auto-hides)
    in-out property<string> toast_message: "";
    // Peer code feedback: set by Rust after KD_AddPeerFingerprint
    in-out property<bool> peer_code_added: false;
    in-out property<bool> peer_code_error: false;
    in property<string> connect_status: "";
    // Version string from Go (set by Rust at init)
    in property<string> version_text: "";
    // FUSE mode toggle (can be changed before connecting)
    in-out property<bool> fuse_mode: false;
    in property<bool> fuse_available: false;
    in property<string> fuse_install_hint: "Install macFUSE: macfuse.github.io";
    callback fuse_mode_toggled(bool);
    // Local mode toggle (direct LAN connection, skip relay)
    in-out property<bool> local_mode: false;
    in property<string> local_address: "";
    callback local_mode_toggled(bool);
    // LAN discovery
    in property<string> discovery_name: "";
    in-out property<[DiscoveredPeer]> discovered_peers: [];
    callback discovery_peer_selected(int); // called with peer index

    // Callbacks
    callback add_peer_code();
    callback copy_my_code();
    callback create_room_pressed();
    callback join_room_pressed();
    callback connect_pressed();
    callback disconnect_pressed();
    callback export_logs_pressed();
    callback cancel_connect_pressed();
    callback open_folder_pressed();
    callback add_file_pressed();
    callback save_file(string);
    callback open_file(string);
    callback pause_file(string);
    callback save_all_pressed();
    callback exit_pressed();
    callback open_fuse_install();
    callback save_settings(string, string, string); // relay, save_path, mount_path

    // Contacts / Identity
    in-out property<[ContactInfo]> contacts: [];
    in-out property<bool> incognito_mode: false;
    in-out property<bool> peer_is_persistent: false;
    in-out property<bool> peer_already_saved: false;
    in-out property<bool> save_contact_visible: false;
    in-out property<string> save_contact_name: "";
    callback incognito_mode_toggled(bool);
    callback connect_to_contact(int);
    callback save_peer_as_contact(string);
    callback remove_contact(int);

    // Identity hardening (passphrase protect)
    in property<bool> passphrase_protect_enabled: false;
    callback passphrase_protect_toggled(bool);

    in-out property<bool> help_visible: false;
    in-out property<bool> settings_visible: false;
    in property<string> cfg_relay: "";
    in property<string> cfg_save_path: "";
    in property<string> cfg_mount_path: "";
    in property<string> cfg_log_file: "";
    in property<string> cfg_config_path: "";

    // Saved files browser (Screen 3)
    in-out property<[FileInfo]> saved_file_list: [];
    in-out property<string> saved_current_folder: "";
    callback view_saved_files();
    callback back_to_connect();
    callback delete_file(string);
    callback open_save_folder();
    callback navigate_saved_folder(string);
    callback back_saved_folder();

    // Opaque backdrop - ensures full coverage on Wayland where
    // Window.background alone may not fill the compositor surface.
    Rectangle {
        width: 100%;
        height: 100%;
        background: #222222;
    }

    // ============ SCREEN 0: Connect ============
    if current_screen == 0: Rectangle {
        width: 100%;
        height: 100%;
        background: #222222;
        property <float> alpha: 0.0;
        opacity: alpha;
        animate opacity { duration: 300ms; easing: ease-out; }
        init => { alpha = 1.0; }

        // Logo top-left
        KeibiDropLogo {
            x: 115px;
            y: 24px;
        }

        // Title
        t1 := Text {
            y: 127px;
            width: parent.width;
            horizontal-alignment: center;
            vertical-alignment: top;
            text: "Connect Securely";
            color: white;
            font-family: "Inter";
            font-size: 23px;
            font-weight: 700;
        }

        // Subtitle
        Text {
            y: t1.y + t1.height + 7px;
            width: parent.width;
            horizontal-alignment: center;
            vertical-alignment: top;
            text: "Exchange fingerprints to establish a secure connection";
            color: white;
            font-family: "Inter";
            font-size: 16px;
            font-weight: 400;
        }

        // Card 1: Enter Code
        SectionElement {
            x: 261px;
            y: 262px;
            height: 170px;
            info: root.local_mode ? "Peer Address" : "Enter Code";
            inText <=> root.peer_code;
            readOnly: false;
            buttonText: "Add";
            process_code => { root.add_peer_code() }
            sectionNumber: 1;
        }

        // Peer code feedback - below input in card 1
        if root.peer_code_added: Text {
            x: 357px;
            y: 390px;
            text: "Peer code added";
            color: #22c55e;
            font-size: 13px;
        }
        if root.peer_code_error: Text {
            x: 357px;
            y: 390px;
            text: "Invalid code. Check that you copied the full code from your peer.";
            color: #d97706;
            font-size: 12px;
            width: 300px;
            wrap: word-wrap;
        }
        if !root.peer_code_added && !root.peer_code_error && !root.local_mode: Text {
            x: 357px;
            y: 390px;
            text: "Paste the code your peer sent you";
            color: #555;
            font-size: 12px;
        }

        // Card 2: Your Code
        snd := SectionElement {
            x: 261px;
            y: 459px;
            height: 178px;
            info: root.local_mode
                ? "Your Address (local network)"
                : "Your Code";
            inText: root.local_mode
                ? (root.local_address != "" ? root.local_address : "No link-local address")
                : (root.my_code != "" ? root.my_code : "XXXX-XXXX-XXXX-XXXX-YYYY-YYYY-YYYY-YYYY");
            readOnly: true;
            buttonText: "Copy";
            helperText: root.local_mode ? "" : "Send this code to your peer via Telegram, Signal, Email or Carrier Pigeon.";
            process_code => { root.copy_my_code() }
            sectionNumber: 2;
        }

        // Connect button (replaces separate Create/Join, role determined by fingerprint tiebreaker)
        if !root.local_mode: PillButton {
            x: 868px;
            y: 459px;
            text: root.room_action != 0 ? "Connecting..." : "Connect";
            active: root.room_action != 0;
            enabled: root.room_action == 0 && root.next_enabled && root.peer_code_added;
            clicked => { root.connect_pressed() }
        }

        // Connect explanation (only when idle, not connecting, not local mode)
        if !root.local_mode && root.room_action == 0 && root.peer_code_added: Text {
            x: 868px;
            y: 497px;
            width: 200px;
            text: "Both peers press Connect.";
            color: #555;
            font-size: 11px;
        }

        // Status text while connecting (countdown timer)
        if root.room_action != 0: Text {
            x: 868px;
            y: 497px;
            width: 340px;
            text: root.connect_status != "" ? root.connect_status : "Connecting...";
            color: #aaa;
            font-size: 12px;
        }

        // Cancel button (while connecting)
        if root.room_action != 0: PillButton {
            x: 868px;
            y: 520px;
            text: "Cancel";
            clicked => { root.cancel_connect_pressed() }
        }

        // FUSE toggle
        Rectangle {
            x: 868px;
            y: 525px;
            width: 260px;
            height: root.fuse_available ? 24px : 40px;
            visible: root.room_action == 0;

            ToggleSwitch {
                x: 0;
                y: 2px;
                checked: root.fuse_mode;
                enabled: root.fuse_available && root.room_action == 0;
                toggled(val) => {
                    root.fuse_mode = val;
                    root.fuse-mode-toggled(val);
                }
            }

            Text {
                x: 44px;
                y: 0;
                height: 24px;
                text: root.fuse_available
                    ? (root.fuse_mode ? "Virtual folder\n(files sync automatically)" : "Direct transfer\n(select files to send)")
                    : "Virtual folder not available";
                color: root.fuse_available ? #ccc : #888888;
                wrap: word-wrap;
                font-size: 12px;
                vertical-alignment: center;
            }

            if !root.fuse_available: Rectangle {
                x: 44px;
                y: 20px;
                width: fuse-hint-text.preferred-width;
                height: 16px;

                fuse-hint-text := Text {
                    text: root.fuse_install_hint;
                    color: fuse-hint-touch.has-hover ? #888 : #555;
                    font-size: 11px;
                }
                fuse-hint-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.open-fuse-install(); }
                }
            }
        }

        // Local mode toggle
        Rectangle {
            x: 868px;
            y: 557px;  // 525+32 = same 32px gap as original
            width: 260px;
            height: 24px;
            visible: root.room_action == 0;

            ToggleSwitch {
                x: 0;
                y: 2px;
                checked: root.local_mode;
                enabled: root.room_action == 0;
                toggled(val) => {
                    root.local_mode = val;
                    root.local-mode-toggled(val);
                }
            }

            Text {
                x: 44px;
                y: 0;
                height: 24px;
                text: root.local_mode
                    ? "Local network\n(direct connection, no relay)"
                    : "Internet\n(connect via relay server)";
                color: #ccc;
                font-size: 12px;
                wrap: word-wrap;
                vertical-alignment: center;
            }

            if !root.local_mode && root.room_action == 0: Text {
                x: 44px;
                y: 28px;
                width: 210px;
                text: "Same WiFi? Toggle to find your peer automatically.";
                color: #444;
                font-size: 10px;
                wrap: word-wrap;
            }
        }

        // Discovery info (shown when local mode is on and not connecting)
        if root.local_mode && root.discovery_name != "" && root.room_action == 0: Text {
            x: 868px;
            y: 636px;
            text: "You appear as: " + root.discovery_name;
            color: #177DF5;
            font-size: 12px;
        }

        if root.local_mode && root.discovered_peers.length > 0 && root.room_action == 0: Text {
            x: 868px;
            y: 656px;
            text: "Nearby devices:";
            color: #94a3b8;
            font-size: 11px;
        }

        for peer[idx] in root.discovered_peers: Rectangle {
            x: 868px;
            y: 672px + idx * 32px;
            width: 250px;
            height: 28px;
            border-radius: 6px;
            visible: root.room_action == 0;
            background: peer-touch.has-hover ? #333 : #2a2a2a;

            Text {
                x: 10px;
                y: 0;
                height: parent.height;
                text: peer.name;
                color: white;
                font-size: 13px;
                vertical-alignment: center;
            }
            Text {
                x: parent.width - 70px;
                y: 0;
                height: parent.height;
                text: "Connect";
                color: #177DF5;
                font-size: 12px;
                vertical-alignment: center;
            }
            peer-touch := TouchArea {
                clicked => { root.discovery-peer-selected(idx); }
            }
        }

        if root.local_mode && root.discovered_peers.length == 0 && root.room_action == 0: Text {
            x: 868px;
            y: 656px;
            text: "Searching for devices...";
            color: #666;
            font-size: 12px;
        }

        // Incognito toggle (below local mode toggle)
        Rectangle {
            x: 868px;
            y: 605px;
            width: 260px;
            height: 24px;
            visible: root.room_action == 0 && !root.local_mode;

            ToggleSwitch {
                x: 0;
                y: 2px;
                checked: root.incognito_mode;
                enabled: root.room_action == 0;
                toggled(val) => {
                    root.incognito_mode = val;
                    root.incognito-mode-toggled(val);
                }
            }

            Text {
                x: 44px;
                y: 0;
                height: 24px;
                text: root.incognito_mode
                    ? "Incognito (new keys each session)"
                    : "Persistent identity (contacts work)";
                color: root.incognito_mode ? #d97706 : #ccc;
                font-size: 12px;
                wrap: word-wrap;
                vertical-alignment: center;
            }
        }

        // Saved contacts panel (only when contacts exist, not connecting, not local mode)
        if root.contacts.length > 0 && root.room_action == 0 && !root.local_mode: Rectangle {
            x: 314px;
            y: 656px;
            width: 517px;
            height: Math.min(root.contacts.length * 36 + 28, 136) * 1px;
            border-radius: 7px;
            background: #262626;
            border-width: 0.5px;
            border-color: rgba(255,255,255,0.10);
            clip: true;

            Text {
                x: 12px;
                y: 6px;
                text: "Contacts (" + root.contacts.length + ")";
                color: #888;
                font-size: 11px;
                font-weight: 600;
            }

            ScrollView {
                x: 12px;
                y: 24px;
                width: parent.width - 24px;
                height: parent.height - 28px;
                viewport-height: root.contacts.length * 36px;

                for contact[idx] in root.contacts: Rectangle {
                    x: 0;
                    y: idx * 36px;
                    width: parent.width - 12px;
                    height: 32px;
                    border-radius: 6px;
                    background: connect-touch.has-hover ? #333 : transparent;

                    Rectangle {
                        x: 0;
                        y: (parent.height - 8px) / 2;
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: contact.online ? #22c55e : #555;
                    }

                    Text {
                        x: 16px;
                        y: 0;
                        height: parent.height;
                        text: contact.name;
                        color: white;
                        font-size: 13px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: 200px;
                        y: 0;
                        width: 200px;
                        height: parent.height;
                        text: contact.fingerprint;
                        color: #555;
                        font-size: 11px;
                        font-family: "monospace";
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    // Connect link
                    Rectangle {
                        x: parent.width - 100px;
                        y: 0;
                        width: 50px;
                        height: parent.height;
                        Text {
                            text: "Connect";
                            color: connect-touch.has-hover ? #60a5fa : #3b82f6;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        connect-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.connect-to-contact(idx); }
                        }
                    }

                    // Delete link
                    Rectangle {
                        x: parent.width - 30px;
                        y: 0;
                        width: 24px;
                        height: parent.height;
                        Text {
                            text: "X";
                            color: delete-touch.has-hover ? #ef4444 : #666;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        delete-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.remove-contact(idx); }
                        }
                    }
                }
            }
        }

        // Status message (only when NOT connecting; connecting state uses connect_status above)
        if root.status_message != "" && root.error_message == "" && root.room_action == 0: Text {
            x: 868px;
            y: 636px + (root.local_mode ? 80px : 0px);
            text: root.status_message;
            color: #94a3b8;
            font-size: 12px;
        }
        if root.error_message != "": Rectangle {
            x: 261px;
            y: 660px;
            width: 580px;
            height: 44px;
            border-radius: 7px;
            background: rgba(239,68,68,0.08);
            border-width: 0.5px;
            border-color: rgba(239,68,68,0.25);

            Text {
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text: root.error_message;
                color: #ef4444;
                font-size: 12px;
                horizontal-alignment: left;
                vertical-alignment: center;
                wrap: word-wrap;
                overflow: elide;
            }
        }

    }

    // ============ SCREEN 1: Connected (No FUSE) ============
    if current_screen == 1: Rectangle {
        width: 100%;
        height: 100%;
        background: #1f1f1f;
        property <float> alpha: 0.0;
        opacity: alpha;
        animate opacity { duration: 300ms; easing: ease-out; }
        init => { alpha = 1.0; }

        // Logo top-left (matches design)
        KeibiDropLogo {
            x: 115px;
            y: 24px;
        }

        // Connected status - below logo
        HorizontalLayout {
            x: 115px;
            y: 55px;
            height: 22px;
            spacing: 8px;
            alignment: start;

            Rectangle {
                width: 8px;
                height: 8px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: #22c55e;
            }
            Text {
                text: "Connected";
                color: #22c55e;
                font-size: 13px;
                vertical-alignment: center;
            }
            if root.connection_mode != "": Rectangle {
                width: mode-text.preferred-width + 14px;
                height: 20px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: root.connection_mode == "lan" ? rgba(34,197,94,0.12)
                          : root.connection_mode == "direct" ? rgba(59,130,246,0.12)
                          : rgba(217,119,6,0.12);
                mode-text := Text {
                    text: root.connection_mode == "lan" ? "LAN"
                        : root.connection_mode == "direct" ? "Direct P2P"
                        : root.connection_mode == "bridge" ? "Via Relay"
                        : root.connection_mode;
                    color: root.connection_mode == "lan" ? #22c55e
                         : root.connection_mode == "direct" ? #3b82f6
                         : #d97706;
                    font-size: 11px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Save Peer button (no-FUSE, aligned under gear/?/X)
        if root.peer_is_persistent && !root.incognito_mode && !root.peer_already_saved: SmallOutlineButton {
            x: 973px;
            y: 125px;
            width: 88px;
            text: "Save Peer";
            clicked => { root.save_contact_visible = true; }
        }

        // Save All button - aligned with global top-right buttons
        SmallOutlineButton {
            x: 700px;
            y: 93px;
            width: 70px;
            text: "Save All";
            clicked => { root.save_all_pressed() }
        }

        // "+" circle always visible, spins only during drag-hover or active transfers
        SpinnerArc {
            x: (parent.width - self.width) / 2;
            y: 90px;
            size: 180px;
            spinning: root.drag_hovering || root.any_downloading;
            clicked => { root.add_file_pressed() }
        }

        // Back button (visible when inside a folder)
        if root.current_folder != "" : Rectangle {
            y: 310px;
            x: 40px;
            width: 200px;
            height: 30px;

            Text {
                text: "< Back";
                color: #60a5fa;
                font-size: 14px;
                vertical-alignment: center;
            }

            TouchArea {
                clicked => { root.back_folder() }
            }
        }

        // Current folder label
        if root.current_folder != "" : Text {
            y: 312px;
            x: 250px;
            text: root.current_folder;
            color: #9ca3af;
            font-size: 13px;
        }

        // Scrollable file grid
        ScrollView {
            y: root.current_folder != "" ? 345px : 310px;
            width: parent.width;
            height: parent.height - (root.current_folder != "" ? 345px : 310px);
            viewport-height: Math.ceil(root.file_list.length / 4) * 200px;

            for file[idx] in root.file_list: FileCard {
                x: 40px + mod(idx, 4) * 265px;
                y: floor(idx / 4) * 200px;
                filename: file.name;
                file-type: file.file-type;
                size-bytes: file.size-bytes;
                downloading: file.downloading;
                uploading: file.uploading;
                progress: file.progress;
                saved: file.saved;
                is-local: file.is-local;
                paused: file.paused;
                save-clicked => {
                    if file.file-type == "folder" {
                        root.navigate_folder(file.name)
                    } else {
                        root.save_file(file.name)
                    }
                }
                open-clicked => {
                    if file.file-type == "folder" {
                        root.navigate_folder(file.name)
                    } else {
                        root.open_file(file.name)
                    }
                }
                pause-clicked => { root.pause_file(file.name) }
            }
        }
    }

    // ============ SCREEN 2: Connected (FUSE present) ============
    if current_screen == 2: Rectangle {
        width: 100%;
        height: 100%;
        background: #1f1f1f;
        property <float> alpha: 0.0;
        opacity: alpha;
        animate opacity { duration: 300ms; easing: ease-out; }
        init => { alpha = 1.0; }

        // Logo top-left (matches design)
        KeibiDropLogo {
            x: 115px;
            y: 24px;
        }

        // Connected status - below logo
        HorizontalLayout {
            x: 115px;
            y: 55px;
            height: 22px;
            spacing: 8px;
            alignment: start;

            Rectangle {
                width: 8px;
                height: 8px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: #22c55e;
            }
            Text {
                text: "Connected · FUSE mounted";
                color: #22c55e;
                font-size: 13px;
                vertical-alignment: center;
            }
            if root.connection_mode != "": Rectangle {
                width: fuse-mode-text.preferred-width + 14px;
                height: 20px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: root.connection_mode == "lan" ? rgba(34,197,94,0.12)
                          : root.connection_mode == "direct" ? rgba(59,130,246,0.12)
                          : rgba(217,119,6,0.12);
                fuse-mode-text := Text {
                    text: root.connection_mode == "lan" ? "LAN"
                        : root.connection_mode == "direct" ? "Direct P2P"
                        : root.connection_mode == "bridge" ? "Via Relay"
                        : root.connection_mode;
                    color: root.connection_mode == "lan" ? #22c55e
                         : root.connection_mode == "direct" ? #3b82f6
                         : #d97706;
                    font-size: 11px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ── Main content ─────────────────────────────────────────
        VerticalLayout {
            alignment: center;
            spacing: 16px;
            padding-left: 120px;
            padding-right: 120px;

            Text {
                text: "📁";
                font-size: 56px;
                color: white;
                horizontal-alignment: center;
            }

            Text {
                text: "Shared folder is live";
                color: white;
                font-size: 24px;
                font-weight: 700;
                horizontal-alignment: center;
            }

            Text {
                text: "Drop files into the folder to share them instantly with your peer.";
                color: #9ca3af;
                font-size: 15px;
                horizontal-alignment: center;
            }

            Text {
                text: "Files stream on access. Open videos, documents, or code without waiting for the full download.";
                color: #666;
                font-size: 12px;
                horizontal-alignment: center;
            }

            if root.mount_path != "": Rectangle {
                height: 38px;
                border-radius: 19px;
                background: rgba(255,255,255,0.05);
                border-width: 1px;
                border-color: rgba(255,255,255,0.10);
                horizontal-stretch: 0;

                HorizontalLayout {
                    alignment: center;
                    padding-left: 16px;
                    padding-right: 16px;
                    Text {
                        text: root.mount_path;
                        color: #64748b;
                        font-size: 13px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            HorizontalLayout {
                alignment: center;
                spacing: 12px;
                OutlineButton {
                    text: "Open Folder";
                    clicked => { root.open_folder_pressed() }
                }
                if root.peer_is_persistent && !root.incognito_mode && !root.peer_already_saved: OutlineButton {
                    text: "Save Peer";
                    clicked => { root.save_contact_visible = true; }
                }
            }
        }
    }

    // ============ SCREEN 3: Saved Files Browser ============
    if current_screen == 3: Rectangle {
        width: 100%;
        height: 100%;
        background: #1f1f1f;
        property <float> alpha: 0.0;
        opacity: alpha;
        animate opacity { duration: 300ms; easing: ease-out; }
        init => { alpha = 1.0; }

        // Logo top-left
        KeibiDropLogo {
            x: 115px;
            y: 24px;
        }

        // Header row: back + title + count left, utilities right
        OutlineButton {
            x: 40px;
            y: 88px;
            width: 90px;
            accent: true;
            text: "\u{2190} Back";
            clicked => { root.back_to_connect() }
        }

        Text {
            x: 140px;
            y: 91px;
            text: "Saved Files";
            color: white;
            font-size: 23px;
            font-weight: 700;
        }

        Text {
            x: 305px;
            y: 99px;
            text: root.saved_file_list.length == 1
                ? "1 file"
                : root.saved_file_list.length + " files";
            color: #9ca3af;
            font-size: 13px;
        }

        SmallOutlineButton {
            x: 832px;
            y: 93px;
            width: 85px;
            text: "Open Folder";
            clicked => { root.open_save_folder() }
        }

        // Folder navigation (inside saved files)
        if root.saved_current_folder != "": Rectangle {
            y: 130px;
            x: 40px;
            width: 200px;
            height: 30px;

            Text {
                text: "< Back";
                color: #60a5fa;
                font-size: 14px;
                vertical-alignment: center;
            }

            TouchArea {
                mouse-cursor: pointer;
                clicked => { root.back_saved_folder() }
            }
        }

        if root.saved_current_folder != "": Text {
            y: 132px;
            x: 250px;
            width: parent.width - 260px;
            text: root.saved_current_folder;
            color: #9ca3af;
            font-size: 13px;
            overflow: elide;
        }

        // Empty state
        if root.saved_file_list.length == 0: VerticalLayout {
            alignment: center;
            spacing: 8px;

            Text {
                text: "No saved files";
                color: #9ca3af;
                font-size: 16px;
                horizontal-alignment: center;
            }

            Text {
                text: "Files you download will appear here";
                color: #555;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }

        // File grid (same column layout as Screen 1)
        if root.saved_file_list.length > 0: ScrollView {
            y: root.saved_current_folder != "" ? 165px : 130px;
            width: parent.width;
            height: parent.height - (root.saved_current_folder != "" ? 165px : 130px);
            viewport-height: Math.ceil(root.saved_file_list.length / 4) * 200px;

            for file[idx] in root.saved_file_list: FileCard {
                x: 40px + mod(idx, 4) * 265px;
                y: floor(idx / 4) * 200px;
                filename: file.name;
                file-type: file.file-type;
                size-bytes: file.size-bytes;
                downloading: false;
                uploading: false;
                progress: 1.0;
                saved: true;
                is-local: true;
                paused: false;
                browse-mode: true;
                open-clicked => {
                    if file.file-type == "folder" {
                        root.navigate_saved_folder(file.name)
                    } else {
                        root.open_file(file.name)
                    }
                }
                save-clicked => {
                    if file.file-type == "folder" {
                        root.navigate_saved_folder(file.name)
                    }
                }
                delete-clicked => { root.delete_file(file.name) }
            }
        }
    }

    // ============ GLOBAL: Top-right buttons (all screens) ============

    // Disconnect button (only when connected, not on Screen 3)
    if root.current_screen == 1 || root.current_screen == 2: SmallOutlineButton {
        x: 780px;
        y: 93px;
        width: 78px;
        text: "Disconnect";
        clicked => { root.disconnect_pressed() }
    }

    // Saved Files button (Screen 0 only, when files exist)
    if root.current_screen == 0 && root.saved_file_list.length > 0: SmallOutlineButton {
        x: 780px;
        y: 93px;
        width: 80px;
        text: "Saved Files";
        clicked => { root.view_saved_files() }
    }

    SmallOutlineButton {
        x: 868px;
        y: 93px;
        width: 96px;
        text: "Save Log";
        clicked => { root.export_logs_pressed() }
    }
    Rectangle {
        x: 973px;
        y: 93px;
        width: 24px;
        height: 24px;
        border-radius: 7px;
        border-width: 0.5px;
        border-color: gear-touch.pressed ? #ccc : gear-touch.has-hover ? #bbb : white;
        background: transparent;
        animate border-color { duration: 150ms; }

        Text {
            text: "\u{2699}";
            color: gear-touch.pressed ? #bbb : gear-touch.has-hover ? #aaa : #888;
            font-size: 14px;
            horizontal-alignment: center;
            vertical-alignment: center;
            y: 4.5px;
        }
        gear-touch := TouchArea {
            clicked => { root.settings_visible = !root.settings_visible; }
        }
    }
    SmallOutlineButton {
        x: 1005px;
        y: 93px;
        width: 24px;
        text: "?";
        clicked => { root.help_visible = !root.help_visible; }
    }
    SmallOutlineButton {
        x: 1037px;
        y: 93px;
        width: 24px;
        text: "X";
        clicked => { root.exit_pressed() }
    }

    // Settings panel overlay
    if root.settings_visible: Rectangle {
        x: (parent.width - 500px) / 2;
        y: (parent.height - 480px) / 2;
        width: 500px;
        height: 480px;
        border-radius: 10px;
        background: #2a2a2a;
        border-width: 1px;
        border-color: rgba(255,255,255,0.12);

        SmallOutlineButton {
            x: parent.width - 36px;
            y: 8px;
            width: 24px;
            text: "X";
            clicked => { root.settings_visible = false; }
        }

        Text {
            x: 20px;
            y: 16px;
            text: "Settings";
            color: white;
            font-size: 16px;
            font-weight: 700;
        }

        // Relay
        Text { x: 20px; y: 56px; text: "Relay server"; color: #888; font-size: 12px; }
        Text { x: 20px; y: 72px; text: root.cfg_relay; color: #ccc; font-size: 13px; font-family: "monospace"; overflow: elide; width: 460px; }

        // Save path
        Text { x: 20px; y: 100px; text: "Save path (received files)"; color: #888; font-size: 12px; }
        Text { x: 20px; y: 116px; text: root.cfg_save_path; color: #ccc; font-size: 13px; font-family: "monospace"; overflow: elide; width: 460px; }

        // Mount path
        Text { x: 20px; y: 144px; text: "Mount path (FUSE virtual folder)"; color: #888; font-size: 12px; }
        Text { x: 20px; y: 160px; text: root.cfg_mount_path; color: #ccc; font-size: 13px; font-family: "monospace"; overflow: elide; width: 460px; }

        // Log file
        Text { x: 20px; y: 188px; text: "Log file"; color: #888; font-size: 12px; }
        Text { x: 20px; y: 204px; text: root.cfg_log_file; color: #ccc; font-size: 13px; font-family: "monospace"; overflow: elide; width: 460px; }

        // Config file
        Text { x: 20px; y: 232px; text: "Config file"; color: #888; font-size: 12px; }
        Text { x: 20px; y: 248px; text: root.cfg_config_path; color: #ccc; font-size: 13px; font-family: "monospace"; overflow: elide; width: 460px; }

        // Version
        Text { x: 20px; y: 284px; text: "Version"; color: #888; font-size: 12px; }
        Text { x: 20px; y: 300px; text: root.version_text; color: #ccc; font-size: 13px; }

        // Passphrase protect toggle
        Rectangle {
            x: 20px;
            y: 334px;
            width: parent.width - 40px;
            height: 24px;

            ToggleSwitch {
                x: 0;
                y: 2px;
                checked: root.passphrase_protect_enabled;
                toggled(val) => {
                    root.passphrase-protect-toggled(val);
                }
            }

            Text {
                x: 44px;
                y: 0;
                height: 24px;
                text: "Encrypt identity with a passphrase";
                color: #ccc;
                font-size: 13px;
                vertical-alignment: center;
            }
        }

        // Hint
        Text {
            x: 20px;
            y: parent.height - 32px;
            text: "Edit ~/.config/keibidrop/config.toml to change settings. Restart to apply.";
            color: #555;
            font-size: 11px;
        }
    }

    // Help panel overlay
    if root.help_visible: Rectangle {
        x: (parent.width - 440px) / 2;
        y: (parent.height - 320px) / 2;
        width: 440px;
        height: 320px;
        border-radius: 10px;
        background: #2a2a2a;
        border-width: 1px;
        border-color: rgba(255,255,255,0.12);

        // Close button
        SmallOutlineButton {
            x: parent.width - 36px;
            y: 8px;
            width: 24px;
            text: "X";
            clicked => { root.help_visible = false; }
        }

        Text {
            x: 20px;
            y: 16px;
            text: "How to use KeibiDrop";
            color: white;
            font-size: 16px;
            font-weight: 700;
        }

        Text {
            x: 20px;
            y: 48px;
            width: parent.width - 40px;
            wrap: word-wrap;
            color: #bbb;
            font-size: 13px;
            text: root.current_screen == 0
                ? "1. Copy your code and send it to your peer\n2. Paste their code and press Add\n3. Press Connect (both peers)\n4. Drag files to share, or toggle Virtual Folder\n\nSaved contacts appear below. Click to reconnect.\n\nIncognito: new keys each session. Peer can't save you.\n\nLocal Network: find devices on the same WiFi.\n\nVirtual Folder: requires macFUSE, fuse3, or WinFsp."
                : root.current_screen == 1
                ? "Drag files onto the window or press Add File.\nYour peer sees your files and can save them.\nClick Save to download a peer's file.\n\nSave Peer adds them to your contacts.\n\nConnection badge:\n  LAN = same network\n  Direct P2P = over the internet\n  Via Relay = through encrypted bridge"
                : "Your peer's files appear in the mounted folder.\nOpen with any app: Finder, Terminal, git, etc.\nFiles stream on access, no full download needed.\n\nDrop files into the folder to share.\nSave Peer adds them to your contacts.";
        }

        Text {
            x: 20px;
            y: parent.height - 28px;
            text: "keibidrop.com";
            color: #555;
            font-size: 11px;
        }
    }

    // Save Contact dialog overlay
    if root.save_contact_visible: Rectangle {
        x: (parent.width - 360px) / 2;
        y: (parent.height - 160px) / 2;
        width: 360px;
        height: 160px;
        border-radius: 10px;
        background: #2a2a2a;
        border-width: 1px;
        border-color: rgba(255,255,255,0.12);

        SmallOutlineButton {
            x: parent.width - 36px;
            y: 8px;
            width: 24px;
            text: "X";
            clicked => { root.save_contact_visible = false; root.save_contact_name = ""; }
        }

        Text {
            x: 20px;
            y: 16px;
            text: "Save Peer as Contact";
            color: white;
            font-size: 16px;
            font-weight: 700;
        }

        Text {
            x: 20px;
            y: 50px;
            text: "Name";
            color: #888;
            font-size: 12px;
        }

        Rectangle {
            x: 20px;
            y: 68px;
            width: parent.width - 40px;
            height: 32px;
            border-radius: 6px;
            border-width: 0.5px;
            border-color: rgba(255,255,255,0.3);
            background: #333;

            contact-name-input := TextInput {
                x: 8px;
                width: parent.width - 16px;
                height: parent.height;
                color: white;
                font-size: 13px;
                vertical-alignment: center;
                single-line: true;
                text <=> root.save_contact_name;
                accepted => {
                    if root.save_contact_name != "" {
                        root.save-peer-as-contact(root.save_contact_name);
                        root.save_contact_visible = false;
                        root.save_contact_name = "";
                    }
                }
            }
        }

        PillButton {
            x: 20px;
            y: 114px;
            width: parent.width - 40px;
            text: "Save";
            enabled: root.save_contact_name != "";
            clicked => {
                if root.save_contact_name != "" {
                    root.save-peer-as-contact(root.save_contact_name);
                    root.save_contact_visible = false;
                    root.save_contact_name = "";
                }
            }
        }
    }

    // Toast notification (bottom-center, all screens)
    if root.toast_message != "": Rectangle {
        x: (parent.width - 280px) / 2;
        y: parent.height - 56px;
        width: 280px;
        height: 32px;
        border-radius: 8px;
        background: rgba(255,255,255,0.10);
        border-width: 0.5px;
        border-color: rgba(255,255,255,0.15);

        Text {
            width: parent.width;
            height: parent.height;
            text: root.toast_message;
            color: #ccc;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Version text bottom-right (all screens)
    Text {
        x: parent.width - self.width - 16px;
        y: parent.height - self.height - 12px;
        text: root.version_text;
        color: #666666;
        font-size: 11px;
        font-family: "Inter";
    }
}

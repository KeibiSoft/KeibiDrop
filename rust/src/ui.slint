import { Button, VerticalBox, ScrollView } from "std-widgets.slint";

// File info model for dynamic file list
export struct FileInfo {
    name: string,
    size-bytes: int,
    downloading: bool,    // I'm downloading this file
    uploading: bool,      // peer is downloading this file from me
    progress: float,      // 0.0 to 1.0
    saved: bool,
    file-type: string,    // "pdf", "image", "video", "audio", "code", "archive", "text", "other"
    is-local: bool,       // true = my file (shared by me), false = remote file (from peer)
}

component CustomButton inherits Rectangle {
    in-out property text <=> txt.text;
    callback clicked <=> touch.clicked;
    border-radius: root.height / 2;
    border-width: 1px;
    border-color: root.background.darker(25%);
    background: touch.pressed ? #6b8282 : touch.has-hover ? #6c616c :  #456;
    height: txt.preferred-height * 1.33;
    min-width: txt.preferred-width + 20px;
    txt := Text {
        x: (parent.width - self.width)/2 + (touch.pressed ? 2px : 0);
        y: (parent.height - self.height)/2 + (touch.pressed ? 1px : 0);
        color: touch.pressed ? #fff : #eee;
    }
    touch := TouchArea { }
}

component InputArea inherits Rectangle {
    in-out property <string> inText: "xxx-xxx-xxx";
    in property <bool> readOnly: false;
    in property <string> buttonText: "Copy";
    in property <int> paddingFromTop: 35;

    callback process_code;

    width: 445px;
    height: 34px;
    background: #222222;
    border-color: #FFFFFF;
    
    ti := TextInput {
        x: 0px;
        width: 303px;
        height: 34px;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-weight: 0.5;
        text <=> parent.inText;
        // vertical-alignment: center;
        // horizontal-alignment: center;
        // clicked => { self.focus(); }
        read-only: parent.readOnly;
        single-line: true;
    }

    Button{
        x: ti.x + ti.width;
        y: ti.y;
        text: buttonText;
        height: 34px;
        width: 142px;
        clicked => {
            parent.process_code();
        }
    }

}

component DataRectangle inherits Rectangle {
    in property <string> info: "code";
    in-out property <string> inText;
    in property <string> buttonText;
    in property <bool> readOnly;

    callback process_code;

    width: 517px;
    height: 86px;

    t:= Text {
        x: 36px;
        y: 0;
        text: parent.info;
    }

    InputArea {
        x: 36px;
        y: t.y + 21px;
        inText <=> parent.inText;
        buttonText: parent.buttonText;
        readOnly: parent.readOnly;
        process_code => {parent.process_code()}
    }
}

component NumberedToolTip inherits Rectangle {
    in property <int> number: 1;
    width: 34px;
    height: 34px;
    border-width: 1px;
    border-color: rgba(255,255,255,0.06);
    border-radius: 8px;

    Text {
        text: number;
    }
}

component CodeRectangle inherits Rectangle {
    in property <string> info: "code";
    in-out property <string> inText;
    in property <string> buttonText;
    in property <bool> readOnly;
    out property <string> codeData;

    callback process_code;

    width: 517px;
    height: 157px;
    border-width: 1px;
    border-color: rgba(255,255,255,0.06);
    border-radius: 8px;
    // padding: 18px;
    background: #262626;

    DataRectangle {
        info: parent.info;
        inText <=> parent.inText;
        buttonText: parent.buttonText;
        readOnly: parent.readOnly;
        process_code => {parent.process_code()}
    }

}

component SectionElement inherits Rectangle {
    in property <string> info: "code";
    in-out property <string> inText;
    in property <string> buttonText;
    in property <bool> readOnly;
    in property <int> sectionNumber;
    
    callback  process_code;

    height: 157px;
    width: 569px;

   nt := NumberedToolTip{
        number: parent.sectionNumber;
        x:0;
        y:0;
    }

    CodeRectangle{
        x: nt.x + nt.width + 18px;
        y: 0;
        info: parent.info;
        inText <=> parent.inText;
        readOnly: parent.readOnly;
        buttonText: parent.buttonText;
        process_code => {parent.process_code()}
    }


}

component KeibiDropLogo inherits Rectangle {
        // spacing: 1px;
        width: keibi.width + drop.width;
        height: keibi.height;

        keibi := Text {
            text: "KEIBI";
            color: white;
            font-family: "Inter";
            font-size: 26px;
            font-weight: 700;
        }

        drop:= Text {
            text: "DROP";
            color: white;
            font-family: "Inter";
            font-size: 26px;
            font-weight: 200;
            x: keibi.x + keibi.width;
            y: keibi.y;
        }
}


// Outline button (blue border, transparent bg)
component OutlineButton inherits Rectangle {
    in-out property <string> text: "Button";
    in property <bool> enabled: true;
    callback clicked;

    width: 161px;
    height: 34px;
    background: transparent;
    border-width: 1px;
    border-radius: self.height / 2;
    border-color: !enabled ? #555 : touch.pressed ? #2563eb : touch.has-hover ? #60a5fa : #3b82f6;

    Text {
        text: root.text;
        color: !root.enabled ? #555 : touch.pressed ? #2563eb : touch.has-hover ? #60a5fa : #3b82f6;
        font-size: 14px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    animate border-color { duration: 150ms; }
}

// Simple rotating spinner arc
component SpinnerArc inherits Rectangle {
    in property <length> size: 180px;
    in property <bool> spinning: true;

    width: size;
    height: size;

    // Continuous rotation using animation-tick
    property <float> angle: mod(animation-tick() / 8ms, 360);

    // Background ring
    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: self.width / 2;
        border-width: 6px;
        border-color: #334155;
        background: transparent;
    }

    // Rotating arc
    Path {
        x: 0;
        y: 0;
        width: root.size;
        height: root.size;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 100;
        viewbox-height: 100;
        stroke: #3b82f6;
        stroke-width: 3px;
        stroke-line-cap: round;
        fill: transparent;

        property <float> start: spinning ? angle : 0;
        property <float> arc-len: 90;
        property <float> r: 47;
        property <float> cx: 50;
        property <float> cy: 50;

        property <float> x1: cx + r * sin(start * 1deg);
        property <float> y1: cy - r * cos(start * 1deg);
        property <float> x2: cx + r * sin((start + arc-len) * 1deg);
        property <float> y2: cy - r * cos((start + arc-len) * 1deg);

        commands: "M " + x1 + " " + y1 + " A " + r + " " + r + " 0 0 1 " + x2 + " " + y2;
    }

    // Center "+" icon
    Text {
        text: "+";
        font-size: root.size * 0.35;
        color: #3b82f6;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Small spinner for file cards (configurable color)
component SmallSpinner inherits Rectangle {
    in property <bool> active: true;
    in property <color> accent: #3b82f6;  // blue default

    width: 20px;
    height: 20px;

    property <float> angle: active ? mod(animation-tick() / 6ms, 360) : 0;

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: self.width / 2;
        background: root.accent.darker(60%);
    }

    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 20;
        viewbox-height: 20;
        stroke: root.accent;
        stroke-width: 2px;
        stroke-line-cap: round;
        fill: transparent;

        property <float> r: 7;
        property <float> cx: 10;
        property <float> cy: 10;
        property <float> start: angle;
        property <float> arc-len: 120;

        property <float> x1: cx + r * sin(start * 1deg);
        property <float> y1: cy - r * cos(start * 1deg);
        property <float> x2: cx + r * sin((start + arc-len) * 1deg);
        property <float> y2: cy - r * cos((start + arc-len) * 1deg);

        commands: "M " + x1 + " " + y1 + " A " + r + " " + r + " 0 0 1 " + x2 + " " + y2;
    }
}

// File type icon (emoji-based placeholder for different file types)
component FileTypeIcon inherits Rectangle {
    in property <string> file-type: "other";

    width: 48px;
    height: 48px;
    background: transparent;

    // Icon text based on file type
    Text {
        text: root.file-type == "pdf" ? "PDF"
            : root.file-type == "image" ? "IMG"
            : root.file-type == "video" ? "VID"
            : root.file-type == "audio" ? "SND"
            : root.file-type == "code" ? "</>"
            : root.file-type == "archive" ? "ZIP"
            : root.file-type == "text" ? "TXT"
            : "FILE";
        color: root.file-type == "pdf" ? #ef4444
             : root.file-type == "image" ? #22c55e
             : root.file-type == "video" ? #a855f7
             : root.file-type == "audio" ? #f59e0b
             : root.file-type == "code" ? #3b82f6
             : root.file-type == "archive" ? #f97316
             : #9ca3af;
        font-size: 16px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Progress bar
component ProgressBar inherits Rectangle {
    in property <float> progress: 0.0;  // 0.0 to 1.0

    width: 100%;
    height: 4px;
    background: #334155;
    border-radius: 2px;

    Rectangle {
        width: parent.width * clamp(root.progress, 0, 1);
        height: 100%;
        background: root.progress >= 1.0 ? #22c55e : #3b82f6;
        border-radius: 2px;

        animate width { duration: 300ms; easing: ease-out; }
        animate background { duration: 300ms; }
    }
}

// File card for non-FUSE mode (original design + progress)
component FileCard inherits Rectangle {
    in property <string> filename: "Project 123";
    in property <string> file-type: "other";
    in property <bool> downloading: false;
    in property <bool> uploading: false;
    in property <float> progress: 0.0;
    in property <bool> saved: false;
    in property <bool> is-local: false;

    callback save-clicked;
    callback open-clicked;

    width: 250px;
    height: 180px;
    background: transparent;

    // Preview area (original grey style)
    Rectangle {
        width: parent.width;
        height: 140px;
        background: #3a3a3a;
        border-radius: 4px;

        // File type icon centered
        FileTypeIcon {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2 - 10px;
            file-type: root.file-type;
        }

        // Green spinner: downloading from peer (top-left)
        if root.downloading: SmallSpinner {
            x: 8px;
            y: 8px;
            active: true;
            accent: #22c55e;
        }

        // Blue spinner: uploading to peer (top-right)
        if root.uploading: SmallSpinner {
            x: parent.width - 28px;
            y: 8px;
            active: true;
            accent: #3b82f6;
        }

        // Progress bar at bottom of preview area
        if root.downloading: ProgressBar {
            x: 8px;
            y: parent.height - 18px;
            width: parent.width - 16px;
            progress: root.progress;
        }

        // Progress percentage
        if root.downloading: Text {
            y: parent.height - 14px;
            horizontal-alignment: center;
            text: Math.round(root.progress * 100) + "%";
            color: #22c55e;
            font-size: 10px;
        }

        // Saved checkmark
        if root.saved && !root.downloading: Text {
            x: parent.width - 30px;
            y: 8px;
            text: "OK";
            color: #22c55e;
            font-size: 12px;
            font-weight: 700;
        }
    }

    // Bottom row (original style)
    HorizontalLayout {
        y: 148px;
        height: 28px;
        spacing: 8px;

        // Checkbox placeholder
        Rectangle {
            width: 20px;
            height: 20px;
            border-width: 1px;
            border-color: #666;
            border-radius: 4px;
        }

        Text {
            text: filename;
            color: white;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }

        OutlineButton {
            width: 80px;
            height: 28px;
            text: root.downloading ? Math.round(root.progress * 100) + "%"
                : root.is-local ? "Open"
                : root.saved ? "Open"
                : "Save";
            enabled: !root.downloading;
            clicked => {
                if (root.is-local || root.saved) { root.open-clicked(); }
                else { root.save-clicked(); }
            }
        }
    }
}



export component MainWindow inherits Window {
    title: "KEIBIDROP";
    default-font-family: "Inter";
    width: 1144px;
    height: 729px;
    background: #1f1f1f;

    // Data bindings from Rust
    in property<string> my_code: "XXXX-XXXX-XXXX-XXXX";
    in-out property<string> peer_code: "";
    in property<bool> next_enabled: true;

    // Screen state: 0 = connect, 1 = connected (no-fuse), 2 = connected (fuse)
    in-out property<int> current_screen: 0;

    // Error message (shown on connect screen)
    in-out property<string> error_message: "";

    // Room action state: 0=none, 1=creating, 2=joining
    in-out property<int> room_action: 0;
    // Status message (shown below buttons on connect screen)
    in-out property<string> status_message: "";

    // Dynamic file list model (populated by Rust file watcher)
    in-out property<[FileInfo]> file_list: [];
    // Set by Rust when any file is actively downloading
    in-out property<bool> any_downloading: false;
    // Set by Rust when a file is being dragged over the window
    in-out property<bool> drag_hovering: false;

    // Callbacks
    callback add_peer_code();
    callback copy_my_code();
    callback create_room_pressed();
    callback join_room_pressed();
    callback disconnect_pressed();
    callback open_folder_pressed();
    callback add_file_pressed();
    callback save_file(string);
    callback open_file(string);
    callback exit_pressed();

    // Logo appears on all screens
    KeibiDropLogo {
        x: 115px;
        y: 70px;
    }

    // Exit button (top-right, all screens)
    OutlineButton {
        x: parent.width - 80px;
        y: 20px;
        width: 60px;
        height: 28px;
        text: "Exit";
        clicked => { root.exit_pressed() }
    }

    // ============ SCREEN 0: Connect ============
    if current_screen == 0: Rectangle {
        width: 100%;
        height: 100%;
        background: #1f1f1f;

        t1 := Text {
            y: 127px;
            horizontal-alignment: center;
            vertical-alignment: top;
            text: "Connect Securely";
            color: white;
            font-family: "Inter";
            font-size: 23px;
            font-weight: 800;
        }

        Text {
            y: t1.y + t1.height + 7px;
            horizontal-alignment: center;
            vertical-alignment: top;
            text: "Exchange the secret codes to establish a secure connection";
            color: white;
            font-family: "Inter";
            font-size: 16px;
            font-weight: 400;
        }

        SectionElement {
            x: 279px;
            y: 262px;
            info: "Enter Code";
            inText <=> root.peer_code;
            readOnly: false;
            buttonText: "Add";
            process_code => { root.add_peer_code() }
            sectionNumber: 1;
        }

        snd := SectionElement {
            x: 279px;
            y: 437px;
            info: "Send this Code via signal/ telegram/ email/ carrier pidgeon";
            inText: root.my_code != "" ? root.my_code : "XXXX-XXXX-XXXX-XXXX-YYYY-YYYY-YYYY-YYYY";
            readOnly: true;
            buttonText: "Copy";
            process_code => { root.copy_my_code() }
            sectionNumber: 2;
        }

        Rectangle {
            x: snd.x + snd.width + 38px;
            y: snd.y + snd.height - 34px;
            width: 161px;
            height: 34px;
            background: root.room_action == 1 ? #3b82f6 : transparent;
            border-width: 1px;
            border-radius: self.height / 2;
            border-color: root.room_action != 0 && root.room_action != 1 ? #555 : create-touch.pressed ? #2563eb : create-touch.has-hover ? #60a5fa : #3b82f6;
            Text {
                text: root.room_action == 1 ? "Creating..." : "Create Room";
                color: root.room_action == 1 ? white : root.room_action != 0 ? #555 : create-touch.pressed ? #2563eb : create-touch.has-hover ? #60a5fa : #3b82f6;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            create-touch := TouchArea {
                enabled: root.room_action == 0 && root.next_enabled;
                clicked => { root.create_room_pressed() }
            }
            animate background { duration: 150ms; }
            animate border-color { duration: 150ms; }
        }

        Rectangle {
            x: snd.x + snd.width + 38px;
            y: snd.y + snd.height - 34px + 44px;
            width: 161px;
            height: 34px;
            background: root.room_action == 2 ? #3b82f6 : transparent;
            border-width: 1px;
            border-radius: self.height / 2;
            border-color: root.room_action != 0 && root.room_action != 2 ? #555 : join-touch.pressed ? #2563eb : join-touch.has-hover ? #60a5fa : #3b82f6;
            Text {
                text: root.room_action == 2 ? "Joining..." : "Join Room";
                color: root.room_action == 2 ? white : root.room_action != 0 ? #555 : join-touch.pressed ? #2563eb : join-touch.has-hover ? #60a5fa : #3b82f6;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            join-touch := TouchArea {
                enabled: root.room_action == 0 && root.next_enabled;
                clicked => { root.join_room_pressed() }
            }
            animate background { duration: 150ms; }
            animate border-color { duration: 150ms; }
        }

        // Status / error message below buttons
        if root.status_message != "" && root.error_message == "": Text {
            x: snd.x + snd.width + 38px;
            y: snd.y + snd.height - 34px + 98px;
            text: root.status_message;
            color: #94a3b8;
            font-size: 13px;
        }
        if root.error_message != "": Text {
            x: snd.x + snd.width + 38px;
            y: snd.y + snd.height - 34px + 98px;
            text: root.error_message;
            color: #ef4444;
            font-size: 13px;
        }
    }

    // ============ SCREEN 1: Connected (No FUSE) ============
    if current_screen == 1: Rectangle {
        width: 100%;
        height: 100%;
        background: #1f1f1f;

        // Disconnect button top-right
        OutlineButton {
            x: parent.width - 200px;
            y: 70px;
            text: "Disconnect";
            clicked => { root.disconnect_pressed() }
        }

        // Add File button next to disconnect
        OutlineButton {
            x: parent.width - 380px;
            y: 70px;
            text: "Add File";
            clicked => { root.add_file_pressed() }
        }

        // Large spinner: visible during drag-and-drop or when files are downloading
        if root.drag_hovering || root.any_downloading: SpinnerArc {
            x: (parent.width - self.width) / 2;
            y: 140px;
            size: 180px;
            spinning: true;
        }

        // Dynamic file grid (4 per row, positioned like original)
        for file[idx] in root.file_list: FileCard {
            x: 120px + mod(idx, 4) * 270px;
            y: 380px + floor(idx / 4) * 200px;
            filename: file.name;
            file-type: file.file-type;
            downloading: file.downloading;
            uploading: file.uploading;
            progress: file.progress;
            saved: file.saved;
            is-local: file.is-local;
            save-clicked => { root.save_file(file.name) }
            open-clicked => { root.open_file(file.name) }
        }
    }

    // ============ SCREEN 2: Connected (FUSE present) ============
    if current_screen == 2: Rectangle {
        width: 100%;
        height: 100%;
        background: #1f1f1f;

        // Disconnect button top-right
        OutlineButton {
            x: parent.width - 200px;
            y: 70px;
            text: "Disconnect";
            clicked => { root.disconnect_pressed() }
        }

        // Center content below header area
        Rectangle {
            y: 120px;
            height: parent.height - 120px;
            width: 100%;
            background: transparent;

            VerticalLayout {
                alignment: center;
                spacing: 20px;

                Text {
                    text: "Connected!";
                    color: #22c55e;
                    font-size: 32px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Your shared folder is mounted and ready.";
                    color: #9ca3af;
                    font-size: 16px;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Drop files into the folder to share them with your peer.";
                    color: #9ca3af;
                    font-size: 14px;
                    horizontal-alignment: center;
                }

                // Open folder button
                HorizontalLayout {
                    alignment: center;
                    OutlineButton {
                        text: "Open Folder";
                        clicked => { root.open_folder_pressed() }
                    }
                }
            }
        }
    }
}

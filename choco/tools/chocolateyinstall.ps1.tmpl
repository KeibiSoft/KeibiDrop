$ErrorActionPreference = 'Stop'

$toolsDir = "$(Split-Path -Parent $MyInvocation.MyCommand.Definition)"
# TAG has the v prefix (v0.1.1), SEMVER does not (0.1.1)
$url = "https://github.com/KeibiSoft/KeibiDrop/releases/download/${TAG}/keibidrop-${SEMVER}-windows-amd64.zip"

$packageArgs = @{
  packageName    = 'keibidrop'
  unzipLocation  = $toolsDir
  url64bit       = $url
  checksum64     = '${SHA256}'
  checksumType64 = 'sha256'
}

Install-ChocolateyZipPackage @packageArgs

# Add to PATH — binaries are at the root of the zip
Install-ChocolateyPath -PathToInstall $toolsDir -PathType 'Machine'

Write-Host "KeibiDrop installed. Available commands: keibidrop, keibidrop-cli, kd"
Write-Host "WinFsp (required for FUSE support) is installed as a dependency."
